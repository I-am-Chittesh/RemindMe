rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        // Allow Cloud Function to update notified field
        allow write: if request.auth == null && request.writeFields.hasOnly(['notified']);
      }
    }
  }
}